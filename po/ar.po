#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "تفعيل الفجوة السفلية الإضافية"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "إضافة فجوة إضافية في أسفل الشاشة لمنع تداخل شريط الأدوات الرئيسي (dock)."

