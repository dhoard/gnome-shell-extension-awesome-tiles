#: src/extension.js:361
#, javascript-format
msgid "Gap size is now at %d pixel"
msgid_plural "Gap size is now at %d pixels"
msgstr[0] "Abstand ist jetzt bei %d Pixel"
msgstr[1] "Abstände sind jetzt bei %d Pixel"

#: src/extension.js:366
#, javascript-format
msgid "Gap size is now at %d percent"
msgid_plural "Gap size is now at %d percent"
msgstr[0] "Abstand ist jetzt bei %d Prozent"
msgstr[1] "Abstände sind jetzt bei %d Prozent"

#: src/prefs.js:55 src/prefs.js:87
msgid "Behavior"
msgstr "Verhalten"

#: src/prefs.js:64 src/prefs.js:195
msgid "Gaps"
msgstr "Abstände"

#: src/prefs.js:73 src/prefs.js:477
msgid "Shortcuts"
msgstr "Kurzbefehle"

#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Fensteranimationen aktivieren"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Fenster bei Größenänderung oder Neupositionierung animieren (dies kann unter Wayland fehlerhaft sein)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Timeout für Kurzbefehl-Wiederholung in Millisekunden"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "Das Zeitfenster, um einen neuen Tastendruck als Wiederholung zu betrachten."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Schritte für mittiges Kacheln"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Schritte bei jedem Tastendruck (Werte zwischen 0-1)."

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Schritte für seitliches Kacheln"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Verbundenes Ändern der Fenstergröße aktivieren"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "Wenn Sie die Alt-Taste gedrückt halten und die Größe eines Fensters ändern, werden benachbarte gekachelte Fenster zusammen skaliert, um den Abstand beizubehalten."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Akzentfarbe des Themes verwenden"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Leuchtfarbe für verbundenes Ändern"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Benutzerdefinierte Farbe für den Leuchteffekt während der verbundenen Größenänderung (Hex-Format wie #3584e4). Leer lassen, um die Akzentfarbe des Themes zu verwenden."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Pixel für Gap-Größe verwenden"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Pixel anstelle von Prozent für die Gap-Größe verwenden."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Gaps zwischen Fenstern"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Abstände zwischen Fenstern einfügen."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Individuelle Abstände aktivieren"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Konfigurieren Sie separate Gap-Größen für jede Seite (oben, links, unten, rechts) und zwischen den Fenstern."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Oberer Abstand"

#: src/prefs.js:236
msgid "Gap size at the top (percent)."
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:252
msgid "Left Gap Size"
msgstr "Abstand vergrößern"

#: src/prefs.js:253
msgid "Gap size at the left (percent)."
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:269
msgid "Right Gap Size"
msgstr "Rechter Abstand"

#: src/prefs.js:270
msgid "Gap size at the right (percent)."
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:286 src/prefs.js:425
msgid "Bottom Gap Size"
msgstr "Unterer Abstand"

#: src/prefs.js:287
msgid "Gap size at the bottom (percent)."
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:303
msgid "Inner Gap Size"
msgstr "Abstand vergrößern"

#: src/prefs.js:304
msgid "Gap size between windows (percent)."
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:339
msgid "pixels"
msgstr "Pixel"

#: src/prefs.js:339
msgid "percent"
msgstr "Prozent"

#: src/prefs.js:340
msgid "Gap size at the top"
msgstr "Gap-Größe oben"

#: src/prefs.js:341
msgid "Gap size at the left"
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:342
msgid "Gap size at the right"
msgstr "Abstand ist jetzt bei %d Prozent"

#: src/prefs.js:343
msgid "Gap size at the bottom"
msgstr "Gap-Größe unten"

#: src/prefs.js:344
msgid "Gap size between windows"
msgstr "Abstand zwischen Fenster und Arbeitsumgebung"

#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Abstand zwischen Fenster und Arbeitsumgebung"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Prozentsatz, der beim Kacheln eines Fensters als Abstand frei bleibt."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Abstand in Prozent für Platz von Fenstern mit Focus, welche gekachelt sind."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Abstands-Schrittweite"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Die Änderung, die die Kurzbefehle an der Gap-Größe vornehmen."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Zusätzlichen unteren Abstand aktivieren"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Zusätzlichen Abstand am unteren Bildschirmrand hinzufügen, um eine Überlappung mit dem Dock zu verhindern."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Zusätzliche Gap-Größe am unteren Bildschirmrand in Prozent."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Zusätzliche Gap-Größe am unteren Bildschirmrand in Pixeln."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Unterer Abstand nur Hauptbildschirm"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Den zusätzlichen unteren Abstand nur auf dem Hauptbildschirm anwenden."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Kurzbefehle für die Funktionen zuweisen"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Numpad 9 und Numpad 3 Korrektur"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Numpad-Kachel-Fix"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Lösen Sie Konflikte bei Kurzbefehlen zum Wechseln der Arbeitsbereiche auf bestimmten Tastaturen, indem Sie Systemstandardeinstellungen überschreiben, damit sie den Erweiterungseinstellungen entsprechen."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Modifikatortaste für verbundenes Ändern"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "Die Modifikatortaste, die beim Ändern der Größe gedrückt gehalten wird, um verbundenes Ändern auszulösen."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Zum linken Arbeitsbereich wechseln"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Tastenkürzel, um zum linken Arbeitsbereich zu wechseln."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Zum rechten Arbeitsbereich wechseln"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Tastenkürzel, um zum rechten Arbeitsbereich zu wechseln."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Fenster zum linken Arbeitsbereich bewegen"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Tastenkürzel, um das fokussierte Fenster zum linken Arbeitsbereich zu bewegen."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Fenster zum rechten Arbeitsbereich bewegen"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Tastenkürzel, um das fokussierte Fenster zum rechten Arbeitsbereich zu bewegen."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Fenster zentrieren"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Kurzbefehl, um das aktive Fenster ohne Größenänderung mittig auszurichten."

#: src/prefs.js:583
msgid "Increase Gap Size"
msgstr "Abstand vergrößern"

#: src/prefs.js:584
msgid "Shortcut to increase the gap size."
msgstr "Kurzbefehl zum Vergrößern der Gap-Größe."

#: src/prefs.js:594
msgid "Decrease Gap Size"
msgstr "Abstand verringern"

#: src/prefs.js:595
msgid "Shortcut to decrease the gap size."
msgstr "Kurzbefehl zum Verringern der Gap-Größe."

#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Fenster zentrieren"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters in die Mitte."

#: src/prefs.js:616
msgid "Tile Window to Left"
msgstr "Fenster nach links verschieben"

#: src/prefs.js:617
msgid "Shortcut to tile the active window to left."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach links."

#: src/prefs.js:627
msgid "Tile Window to Right"
msgstr "Fenster nach rechts verschieben"

#: src/prefs.js:628
msgid "Shortcut to tile the active window to right."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach rechts."

#: src/prefs.js:638
msgid "Tile Window to Top"
msgstr "Fenster nach oben verschieben"

#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach oben."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Fenster nach unten verschieben"

#: src/prefs.js:650
msgid "Shortcut to tile the active window to bottom."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach unten."

#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Fenster nach links-oben verschieben"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach oben links."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Fenster nach rechts-oben verschieben"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach oben rechts."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Fenster nach links-unten verschieben"

#: src/prefs.js:684
msgid "Shortcut to tile the active window to bottom left."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach unten links."

#: src/prefs.js:694
msgid "Tile Window to Bottom Right"
msgstr "Fenster nach rechts-unten verschieben"

#: src/prefs.js:695
msgid "Shortcut to tile the active window to bottom right."
msgstr "Kurzbefehl zum Kacheln des aktiven Fensters nach unten rechts."

#: src/prefs.js:743
msgid "Disabled"
msgstr "Deaktiviert"

#: src/prefs.js:756
msgid "Default workspace shortcuts (Super + Page Up/Down) conflict with this extension on keyboards where Numpad 9 and 3 share those keys. Enabling this fix overrides system defaults to ensure proper numpad tiling."
msgstr "Die Standard-Kurzbefehle für Arbeitsbereiche (Super + Bild auf/ab) stehen bei Tastaturen, bei denen Numpad 9 und 3 diese Tasten teilen, im Konflikt mit dieser Erweiterung. Das Aktivieren dieser Korrektur überschreibt die Systemvorgaben, um korrektes Kacheln über den Ziffernblock zu gewährleisten."

#: src/prefs.js:760
msgid "Enable Override"
msgstr "Überschreiben aktivieren"

#: src/prefs.js:765
msgid "Close"
msgstr "Schließen"

#: src/prefs.js:771
msgid "About"
msgstr "Über"

#: src/prefs.js:803
msgid "A powerful tiling manager for GNOME Shell. Precision tile windows into 9 positions using the number pad, enjoy dynamic grid sizes that cycle on repeated keystrokes, and experience seamless linked resizing for adjacent windows. Includes customizable gaps, center alignment, and integrated workspace navigation."
msgstr "Ein leistungsstarker Tiling-Manager für die GNOME Shell. Kacheln Sie Fenster präzise in 9 Positionen mit dem Ziffernblock, genießen Sie dynamische Rastergrößen, die bei wiederholten Tastenanschlägen wechseln, und erleben Sie nahtlose verbundene Größenänderungen für benachbarte Fenster. Inklusive anpassbarer Abstände, mittiger Ausrichtung und integrierter Navigation in Arbeitsbereichen."

