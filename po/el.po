#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Παράθεση παραθύρου στο κέντρο"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Συντόμευση για παράθεση του ενεργού παραθύρου στο κέντρο."

#: src/prefs.js:616
