#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Κενό μεταξύ παραθύρου και χώρου εργασίας"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Ποσοστό που θα μείνει ως κενό όταν ένα παράθυρο παρατίθεται."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Pixel που θα μείνουν ως κενό όταν ένα παράθυρο παρατίθεται."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Προσαυξήσεις μεγέθους κενού"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Η αλλαγή που κάνουν οι συντομεύσεις στο μέγεθος του κενού."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Ενεργοποίηση πρόσθετου κάτω κενού"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Προσθέστε ένα επιπλέον κενό στο κάτω μέρος της οθόνης για να αποτρέψετε την επικάλυψη του dock."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Πρόσθετο μέγεθος κενού στο κάτω μέρος της οθόνης σε ποσοστό."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Πρόσθετο μέγεθος κενού στο κάτω μέρος της οθόνης σε pixel."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Κάτω κενό μόνο στην κύρια οθόνη"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Εφαρμογή του πρόσθετου κάτω κενού μόνο στην κύρια οθόνη."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Αντιστοίχιση συντομεύσεων στις λειτουργίες"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Διόρθωση Numpad 9 και Numpad 3"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Διόρθωση παράθεσης Numpad"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Επιλύστε τις συγκρούσεις συντομεύσεων εναλλαγής χώρου εργασίας σε ορισμένα πληκτρολόγια παρακάμπτοντας τις προεπιλογές του συστήματος ώστε να ταιριάζουν με τις ρυθμίσεις της επέκτασης."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Τροποποιητής συνδεδεμένης αλλαγής μεγέθους"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "Το πλήκτρο τροποποίησης που κρατείται κατά την αλλαγή μεγέθους για ενεργοποίηση συνδεδεμένης αλλαγής μεγέθους."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Μετάβαση στον αριστερό χώρο εργασίας"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Συντόμευση για μετάβαση στον χώρο εργασίας στα αριστερά."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Μετάβαση στον δεξιό χώρο εργασίας"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Συντόμευση για μετάβαση στον χώρο εργασίας στα δεξιά."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Μετακίνηση παραθύρου στον αριστερό χώρο εργασίας"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Συντόμευση για μετακίνηση του επιλεγμένου παραθύρου στον χώρο εργασίας στα αριστερά."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Μετακίνηση παραθύρου στον δεξιό χώρο εργασίας"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Συντόμευση για μετακίνηση του επιλεγμένου παραθύρου στον χώρο εργασίας στα δεξιά."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Ευθυγράμμιση παραθύρου στο κέντρο"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Συντόμευση για ευθυγράμμιση του ενεργού παραθύρου στο κέντρο χωρίς αλλαγή μεγέθους."

#: src/prefs.js:583
msgid "Increase Gap Size"
