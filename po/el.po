#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Ενεργοποίηση κινήσεων παραθύρου"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Κίνηση παραθύρων κατά την αλλαγή μεγέθους ή την επανατοποθέτηση (αυτό μπορεί να παρουσιάζει σφάλματα στο Wayland)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Χρονικό όριο επανάληψης συντόμευσης σε χιλιοστά του δευτερολέπτου"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "Το χρονικό παράθυρο για να θεωρηθεί ένα νέο πάτημα πλήκτρου ως επανάληψη."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Βήματα κεντρικής παράθεσης"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Βήματα σε κάθε πάτημα πλήκτρου (τιμές μεταξύ 0-1)."

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Βήματα πλευρικής παράθεσης"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Ενεργοποίηση συνδεδεμένης αλλαγής μεγέθους παραθύρου"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "Όταν κρατάτε πατημένο το Alt και αλλάζετε το μέγεθος ενός παραθύρου, τα γειτονικά παρατιθέμενα παράθυρα θα αλλάζουν μέγεθος μαζί για να διατηρηθεί το κενό."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Χρήση χρώματος έμφασης θέματος"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Χρώμα λάμψης συνδεδεμένης αλλαγής μεγέθους"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Προσαρμοσμένο χρώμα για το εφέ λάμψης κατά τη διάρκεια της συνδεδεμένης αλλαγής μεγέθους (μορφή hex όπως #3584e4). Αφήστε το κενό για να χρησιμοποιήσετε το χρώμα έμφασης του θέματος."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Χρήση Pixel για το μέγεθος κενού"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Χρήση pixel αντί για ποσοστό για το μέγεθος κενού."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Κενά μεταξύ παραθύρων"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Τοποθέτηση κενών μεταξύ των παραθύρων."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Ενεργοποίηση μεμονωμένων μεγεθών κενού"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Διαμορφώστε ξεχωριστά μεγέθη κενού για κάθε πλευρά (πάνω, αριστερά, κάτω, δεξιά) και μεταξύ των παραθύρων."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Μέγεθος πάνω κενού"

#: src/prefs.js:236
