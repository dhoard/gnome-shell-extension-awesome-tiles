#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Παράθεση παραθύρου πάνω αριστερά"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Συντόμευση για παράθεση του ενεργού παραθύρου πάνω αριστερά."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Παράθεση παραθύρου πάνω δεξιά"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Συντόμευση για παράθεση του ενεργού παραθύρου πάνω δεξιά."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Παράθεση παραθύρου κάτω αριστερά"

#: src/prefs.js:684
