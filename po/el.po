#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Συντόμευση για παράθεση του ενεργού παραθύρου στην κορυφή."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Παράθεση παραθύρου στο κάτω μέρος"

#: src/prefs.js:650
