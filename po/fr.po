#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Espace entre une fenêtre et le Workspace"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Pourcentage à laisser comme espacement lorsqu'une fenêtre est tuilée."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Pourcentage à laisser comme espace quand la fenêtre en focus est dimensionnée."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Incrément de la Taille de l'Écart"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Le changement que les raccourcis effectuent sur la taille de l'espacement."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Activer l'espacement inférieur supplémentaire"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Ajoutez un espacement supplémentaire en bas de l'écran pour éviter le chevauchement avec le dock."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Taille de l'espacement supplémentaire en bas de l'écran en pourcentage."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Taille de l'espacement supplémentaire en bas de l'écran en pixels."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Espacement inférieur écran principal uniquement"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Appliquer l'espacement inférieur supplémentaire uniquement sur l'écran principal."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Assigner des raccourcis aux fonctionnalités"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Correction Numpad 9 et Numpad 3"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Correction du tuilage Numpad"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Résolvez les conflits de raccourcis de changement d'espace de travail sur certains claviers en remplaçant les valeurs par défaut du système pour qu'elles correspondent aux paramètres de l'extension."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Modificateur de redimensionnement lié"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "La touche modificatrice maintenue lors du redimensionnement pour déclencher le redimensionnement lié."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Passer à l'espace de travail de gauche"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Raccourci pour placer la fenêtre en focus à gauche."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Passer à l'espace de travail de droite"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Raccourci pour placer la fenêtre en focus à droite."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Placer la Fenêtre en Haut à Gauche"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Raccourci pour placer la fenêtre en focus en haut à gauche."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Placer la Fenêtre en Haut à Droite"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Raccourci pour placer la fenêtre en focus en haut à droite."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Centrer la Fenêtre"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Raccourci pour aligner la fenêtre active au centre sans la redimensionner."

#: src/prefs.js:583
msgid "Increase Gap Size"
msgstr "Augmenter la taille de l'espacement"

#: src/prefs.js:584
msgid "Shortcut to increase the gap size."
msgstr "Raccourci pour augmenter l'espace vide."

#: src/prefs.js:594
msgid "Decrease Gap Size"
msgstr "Diminuer la taille de l'espacement"

#: src/prefs.js:595
msgid "Shortcut to decrease the gap size."
msgstr "Raccourci pour réduire l'espace vide."

#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Placer la Fenêtre au Centre"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Raccourci pour tuiler la fenêtre active au centre."

#: src/prefs.js:616
msgid "Tile Window to Left"
msgstr "Placer la Fenêtre à Gauche"

#: src/prefs.js:617
msgid "Shortcut to tile the active window to left."
msgstr "Raccourci pour tuiler la fenêtre active à gauche."

#: src/prefs.js:627
msgid "Tile Window to Right"
msgstr "Placer la Fenêtre à Droite"

#: src/prefs.js:628
msgid "Shortcut to tile the active window to right."
msgstr "Raccourci pour tuiler la fenêtre active à droite."

#: src/prefs.js:638
msgid "Tile Window to Top"
msgstr "Placer la Fenêtre en Haut"

#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Raccourci pour tuiler la fenêtre active en haut."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Placer la Fenêtre en Bas"

#: src/prefs.js:650
msgid "Shortcut to tile the active window to bottom."
msgstr "Raccourci pour tuiler la fenêtre active en bas."

#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Placer la Fenêtre en Haut à Gauche"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Raccourci pour tuiler la fenêtre active en haut à gauche."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Placer la Fenêtre en Haut à Droite"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Raccourci pour tuiler la fenêtre active en haut à droite."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Placer la Fenêtre en Bas à Gauche"

#: src/prefs.js:684
msgid "Shortcut to tile the active window to bottom left."
msgstr "Raccourci pour tuiler la fenêtre active en bas à gauche."

#: src/prefs.js:694
msgid "Tile Window to Bottom Right"
msgstr "Placer la Fenêtre en Bas à Droite"

#: src/prefs.js:695
msgid "Shortcut to tile the active window to bottom right."
msgstr "Raccourci pour tuiler la fenêtre active en bas à droite."

#: src/prefs.js:743
msgid "Disabled"
msgstr "Désactiver"

#: src/prefs.js:756
msgid "Default workspace shortcuts (Super + Page Up/Down) conflict with this extension on keyboards where Numpad 9 and 3 share those keys. Enabling this fix overrides system defaults to ensure proper numpad tiling."
msgstr "Les raccourcis d'espace de travail par défaut (Super + Page Haut/Bas) entrent en conflit avec cette extension sur les claviers où le pavé numérique 9 et 3 partagent ces touches. L'activation de cette correction remplace les valeurs par défaut du système pour assurer un tuilage correct du pavé numérique."

#: src/prefs.js:760
msgid "Enable Override"
msgstr "Activer le remplacement"

#: src/prefs.js:765
msgid "Close"
msgstr "Fermer"

#: src/prefs.js:771
msgid "About"
msgstr "À propos"

#: src/prefs.js:803
msgid "A powerful tiling manager for GNOME Shell. Precision tile windows into 9 positions using the number pad, enjoy dynamic grid sizes that cycle on repeated keystrokes, and experience seamless linked resizing for adjacent windows. Includes customizable gaps, center alignment, and integrated workspace navigation."
msgstr "Un puissant gestionnaire de tuilage pour GNOME Shell. Tuilez les fenêtres avec précision dans 9 positions en utilisant le pavé numérique, profitez de tailles de grille dynamiques qui changent lors de pressions répétées sur les touches, et expérimentez un redimensionnement lié transparent pour les fenêtres adjacentes. Comprend des espacements personnalisables, l'alignement central et la navigation intégrée dans l'espace de travail."

