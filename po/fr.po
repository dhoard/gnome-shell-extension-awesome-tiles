#: src/prefs.js:55 src/prefs.js:87
msgid "Behavior"
msgstr "Comportement"

#: src/prefs.js:64 src/prefs.js:195
msgid "Gaps"
msgstr "Espacements"

#: src/prefs.js:73 src/prefs.js:477
msgid "Shortcuts"
msgstr "Raccourcis"

#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Activer les animations de fenêtre"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Animer les fenêtres lors du redimensionnement ou du repositionnement (cela peut être buggé sur Wayland)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Délai d'itération du raccourci en millisecondes"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "La fenêtre de temps pour considérer une nouvelle pression de touche comme une itération."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Étapes du Dimensionnement  Central"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Étapes entre chaque touche appuyée (valeurs entre 0 - 1)"

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Étapes du Dimensionnement Latéral"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Activer le redimensionnement lié des fenêtres"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "En maintenant Alt et en redimensionnant une fenêtre, les fenêtres tuilées adjacentes se redimensionneront ensemble pour maintenir l'espacement."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Utiliser la couleur d'accentuation du thème"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Couleur de surbrillance du redimensionnement lié"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Couleur personnalisée pour l'effet de lueur lors du redimensionnement lié (format hexadécimal comme #3584e4). Laissez vide pour utiliser la couleur d'accentuation du thème."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Utiliser des pixels pour la taille de l'espacement"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Utiliser des pixels au lieu d'un pourcentage pour la taille de l'espacement."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Espace Entre les Fenêtres"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Mettre des espaces entre les fenêtres."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Activer les tailles d'espacement individuelles"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Configurez des tailles d'espacement séparées pour chaque côté (haut, gauche, bas, droite) et entre les fenêtres."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Taille de l'espacement en haut"

#: src/prefs.js:236
