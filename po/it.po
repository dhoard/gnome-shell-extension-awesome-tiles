#: src/extension.js:361
#, javascript-format
msgid "Gap size is now at %d pixel"
msgid_plural "Gap size is now at %d pixels"
msgstr[0] "La dimensione del margine è impostata al %d pixel"
msgstr[1] "La dimensione del margine è impostata al %d pixel"

#: src/extension.js:366
#, javascript-format
msgid "Gap size is now at %d percent"
msgid_plural "Gap size is now at %d percent"
