msgstr[1] "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:55 src/prefs.js:87
msgid "Behavior"
msgstr "Comportamento"

#: src/prefs.js:64 src/prefs.js:195
msgid "Gaps"
msgstr "Gap"

#: src/prefs.js:73 src/prefs.js:477
msgid "Shortcuts"
msgstr "Scorciatoie"

#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Abilita animazioni finestre"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Anima le finestre quando ridimensionate o riposizionate (potrebbe esserci qualche bug su Wayland)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Timeout iterazione scorciatoia in millisecondi"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "La finestra temporale per considerare una nuova pressione di tasto come un'iterazione."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Passaggi di affiancamento centrale"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Passaggi ad ogni pressione di tasto (valori tra 0-1)."

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Passaggi di affiancamento laterale"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Abilita ridimensionamento finestre collegato"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "Tenendo premuto Alt e ridimensionando una finestra, le finestre affiancate adiacenti si ridimensioneranno insieme per mantenere il gap."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Usa il colore di accento del tema"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Colore bagliore ridimensionamento collegato"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Colore personalizzato per l'effetto bagliore durante il ridimensionamento collegato (formato esadecimale come #3584e4). Lascia vuoto per utilizzare il colore di accento del tema."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Usa i pixel per la dimensione del gap"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Usa i pixel invece della percentuale per la dimensione del gap."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Gap tra le finestre"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Inserisci gap tra le finestre."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Abilita dimensioni gap individuali"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Configura dimensioni gap separate per ogni lato (alto, sinistro, basso, destro) e tra le finestre."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Dimensione gap superiore"

#: src/prefs.js:236
msgid "Gap size at the top (percent)."
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:252
msgid "Left Gap Size"
msgstr "Aumenta la Dimensione del Margine"

#: src/prefs.js:253
msgid "Gap size at the left (percent)."
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:269
msgid "Right Gap Size"
msgstr "Dimensione gap destro"

#: src/prefs.js:270
msgid "Gap size at the right (percent)."
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:286 src/prefs.js:425
msgid "Bottom Gap Size"
msgstr "Dimensione gap inferiore"

#: src/prefs.js:287
msgid "Gap size at the bottom (percent)."
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:303
msgid "Inner Gap Size"
msgstr "Aumenta la Dimensione del Margine"

#: src/prefs.js:304
msgid "Gap size between windows (percent)."
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:339
msgid "pixels"
msgstr "pixel"

#: src/prefs.js:339
msgid "percent"
msgstr "percento"

#: src/prefs.js:340
msgid "Gap size at the top"
msgstr "Dimensione gap in alto"

#: src/prefs.js:341
msgid "Gap size at the left"
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:342
msgid "Gap size at the right"
msgstr "La dimensione del margine è impostata al %d percento"

#: src/prefs.js:343
msgid "Gap size at the bottom"
msgstr "Dimensione gap in basso"

#: src/prefs.js:344
msgid "Gap size between windows"
msgstr "Margine tra Finestra e Spazio di Lavoro"

#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Margine tra Finestra e Spazio di Lavoro"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Percentuale da lasciare come gap quando una finestra viene affiancata."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Percentuale da lasciare come margine quando la finestra in primo piano è affiancata."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Incrementi dimensione gap"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Il cambiamento che le scorciatoie apportano alla dimensione del gap."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Abilita gap inferiore aggiuntivo"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Aggiungi un gap aggiuntivo nella parte inferiore dello schermo per evitare la sovrapposizione del dock."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Dimensione del gap aggiuntivo nella parte inferiore dello schermo in percentuale."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Dimensione del gap aggiuntivo nella parte inferiore dello schermo in pixel."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Gap inferiore solo schermo principale"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Applica il gap inferiore aggiuntivo solo sullo schermo principale."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Assegna scorciatoie alle funzionalità"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Correzione Numpad 9 e Numpad 3"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Correzione affiancamento tastierino numerico"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Risolvi i conflitti delle scorciatoie per il cambio di spazio di lavoro su determinate tastiere sovrascrivendo le impostazioni predefinite del sistema per corrispondere alle impostazioni dell'estensione."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Modificatore ridimensionamento collegato"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "Il tasto modificatore tenuto premuto durante il ridimensionamento per attivare il ridimensionamento collegato."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Passa allo spazio di lavoro a sinistra"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Scorciatoia per affiancare la finestra in primo piano a sinistra."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Passa allo spazio di lavoro a destra"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Scorciatoia per affiancare la finestra in primo piano a destra."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Affianca Finestra in Alto a Sinistra"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Scorciatoia per affiancare la finestra in primo piano in alto a sinistra."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Affianca Finestra in Alto a Destra"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Scorciatoia per affiancare la finestra in primo piano in alto a destra."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Allinea la Finestra al Centro"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Scorciatoia per allineare la finestra attiva al centro senza ridimensionarla."

#: src/prefs.js:583
msgid "Increase Gap Size"
msgstr "Aumenta dimensione gap"

#: src/prefs.js:584
msgid "Shortcut to increase the gap size."
msgstr "Scorciatoia per aumentare la dimensione del gap."

#: src/prefs.js:594
msgid "Decrease Gap Size"
msgstr "Diminuisci dimensione gap"

#: src/prefs.js:595
msgid "Shortcut to decrease the gap size."
msgstr "Scorciatoia per diminuire la dimensione del gap."

#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Affianca Finestra al Centro"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Scorciatoia per affiancare la finestra attiva al centro."

#: src/prefs.js:616
msgid "Tile Window to Left"
msgstr "Affianca Finestra a Sinistra"

#: src/prefs.js:617
msgid "Shortcut to tile the active window to left."
msgstr "Scorciatoia per affiancare la finestra attiva a sinistra."

#: src/prefs.js:627
msgid "Tile Window to Right"
msgstr "Affianca Finestra a Destra"

#: src/prefs.js:628
msgid "Shortcut to tile the active window to right."
msgstr "Scorciatoia per affiancare la finestra attiva a destra."

#: src/prefs.js:638
msgid "Tile Window to Top"
msgstr "Affianca Finestra in Alto"

#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Scorciatoia per affiancare la finestra attiva in alto."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Affianca Finestra in Basso"

#: src/prefs.js:650
msgid "Shortcut to tile the active window to bottom."
msgstr "Scorciatoia per affiancare la finestra attiva in basso."

#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Affianca Finestra in Alto a Sinistra"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Scorciatoia per affiancare la finestra attiva in alto a sinistra."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Affianca Finestra in Alto a Destra"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Scorciatoia per affiancare la finestra attiva in alto a destra."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Affianca Finestra in Basso a Sinistra"

#: src/prefs.js:684
msgid "Shortcut to tile the active window to bottom left."
msgstr "Scorciatoia per affiancare la finestra attiva in basso a sinistra."

#: src/prefs.js:694
msgid "Tile Window to Bottom Right"
msgstr "Affianca la Finestra in Basso a Destra"

#: src/prefs.js:695
msgid "Shortcut to tile the active window to bottom right."
msgstr "Scorciatoia per affiancare la finestra attiva in basso a destra."

#: src/prefs.js:743
msgid "Disabled"
msgstr "Disabilitato"

#: src/prefs.js:756
msgid "Default workspace shortcuts (Super + Page Up/Down) conflict with this extension on keyboards where Numpad 9 and 3 share those keys. Enabling this fix overrides system defaults to ensure proper numpad tiling."
msgstr "Le scorciatoie predefinite per lo spazio di lavoro (Super + Page Su/Giù) entrano in conflitto con questa estensione su tastiere in cui il tastierino numerico 9 e 3 condividono quei tasti. L'abilitazione di questa correzione sovrascrive i valori predefiniti del sistema per garantire un corretto affiancamento tramite tastierino numerico."

#: src/prefs.js:760
msgid "Enable Override"
msgstr "Abilita sovrascrittura"

#: src/prefs.js:765
msgid "Close"
msgstr "Chiudi"

#: src/prefs.js:771
msgid "About"
msgstr "Informazioni"

#: src/prefs.js:803
msgid "A powerful tiling manager for GNOME Shell. Precision tile windows into 9 positions using the number pad, enjoy dynamic grid sizes that cycle on repeated keystrokes, and experience seamless linked resizing for adjacent windows. Includes customizable gaps, center alignment, and integrated workspace navigation."
msgstr "Un potente gestore di affiancamento per GNOME Shell. Affianca le finestre con precisione in 9 posizioni utilizzando il tastierino numerico, goditi le dimensioni dinamiche della griglia che variano alla pressione ripetuta dei tasti e sperimenta un ridimensionamento collegato senza soluzione di continuità per le finestre adiacenti. Include gap personalizzabili, allineamento centrale e navigazione integrata nello spazio di lavoro."

