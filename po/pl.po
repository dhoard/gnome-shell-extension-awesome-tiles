#: src/prefs.js:55 src/prefs.js:87
msgid "Behavior"
msgstr "Zachowanie"

#: src/prefs.js:64 src/prefs.js:195
msgid "Gaps"
msgstr "Odstępy"

#: src/prefs.js:73 src/prefs.js:477
msgid "Shortcuts"
msgstr "Skróty"

#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Włącz animacje okien"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Animuj okna podczas zmiany ich rozmiaru lub położenia (może działać nieprawidłowo w Wayland)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Limit czasu iteracji skrótu w milisekundach"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "Okno czasowe do uznania nowego naciśnięcia klawisza za iterację."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Kroki kafelkowania na środku"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Kroki przy każdym naciśnięciu klawisza (wartości od 0 do 1)."

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Kroki kafelkowania bocznego"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Włącz powiązane zmienianie rozmiaru okien"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "Przytrzymując Alt i zmieniając rozmiar okna, sąsiednie okna kafelkowe zostaną przeskalowane razem, aby zachować odstęp."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Użyj koloru akcentu motywu"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Kolor poświaty powiązanego zmieniania rozmiaru"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Niestandardowy kolor efektu poświaty podczas powiązanego zmieniania rozmiaru (format szesnastkowy, np. #3584e4). Pozostaw puste, aby użyć koloru akcentu motywu."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Użyj pikseli dla rozmiaru odstępu"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Użyj pikseli zamiast procentów dla rozmiaru odstępu."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Odstępy między oknami"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Dodaj odstępy między oknami."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Włącz indywidualne rozmiary odstępów"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Skonfiguruj oddzielne rozmiary odstępów dla każdej strony (góra, lewo, dół, prawo) oraz między oknami."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Rozmiar odstępu na górze"

#: src/prefs.js:236
msgid "Gap size at the top (percent)."
msgstr "Rozmiar odstępu na górze (procenty)."

#: src/prefs.js:252
msgid "Left Gap Size"
msgstr "Rozmiar odstępu po lewej"

#: src/prefs.js:253
msgid "Gap size at the left (percent)."
msgstr "Rozmiar odstępu po lewej (procenty)."

#: src/prefs.js:269
msgid "Right Gap Size"
msgstr "Rozmiar odstępu po prawej"

#: src/prefs.js:270
msgid "Gap size at the right (percent)."
msgstr "Rozmiar odstępu po prawej (procenty)."

#: src/prefs.js:286 src/prefs.js:425
msgid "Bottom Gap Size"
msgstr "Rozmiar odstępu dolnego"

#: src/prefs.js:287
msgid "Gap size at the bottom (percent)."
msgstr "Rozmiar odstępu na dole (procenty)."

#: src/prefs.js:303
msgid "Inner Gap Size"
msgstr "Rozmiar odstępu wewnętrznego"

#: src/prefs.js:304
msgid "Gap size between windows (percent)."
msgstr "Rozmiar odstępu między oknami (procenty)."

#: src/prefs.js:339
msgid "pixels"
msgstr "pikseli"

#: src/prefs.js:339
msgid "percent"
msgstr "procent"

#: src/prefs.js:340
msgid "Gap size at the top"
msgstr "Rozmiar odstępu na górze"

#: src/prefs.js:341
msgid "Gap size at the left"
msgstr "Rozmiar odstępu po lewej"

#: src/prefs.js:342
msgid "Gap size at the right"
msgstr "Rozmiar odstępu po prawej"

#: src/prefs.js:343
msgid "Gap size at the bottom"
msgstr "Rozmiar odstępu na dole"

#: src/prefs.js:344
msgid "Gap size between windows"
msgstr "Rozmiar odstępu między oknami"

#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Odstęp między oknem a obszarem roboczym"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Procent pozostawiony jako odstęp, gdy okno jest kafelkowane."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Piksele pozostawione jako odstęp, gdy okno jest kafelkowane."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Przyrost rozmiaru odstępu"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Zmiana rozmiaru odstępu przy użyciu skrótów."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Włącz dodatkowy odstęp dolny"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Dodaj dodatkowy odstęp na dole ekranu, aby zapobiec nakładaniu się na dok."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Rozmiar dodatkowego odstępu na dole ekranu w procentach."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Rozmiar dodatkowego odstępu na dole ekranu w pikselach."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Odstęp dolny tylko na głównym ekranie"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Zastosuj dodatkowy odstęp dolny tylko na głównym ekranie."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Przypisz skróty do funkcjonalności"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Napraw Numpad 9 i Numpad 3"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Poprawka kafelkowania Numpad"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Rozwiąż konflikty skrótów przełączania obszarów roboczych na niektórych klawiaturach, nadpisując domyślne ustawienia systemowe zgodnie z ustawieniami rozszerzenia."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Modyfikator powiązanego zmieniania rozmiaru"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "Klawisz modyfikujący przytrzymywany podczas zmiany rozmiaru, aby aktywować powiązane zmienianie rozmiaru."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Przełącz na obszar roboczy po lewej"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Skrót do przełączania na obszar roboczy po lewej."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Przełącz na obszar roboczy po prawej"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Skrót do przełączania na obszar roboczy po prawej."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Przenieś okno na obszar roboczy po lewej"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Skrót do przenoszenia aktywnego okna na obszar roboczy po lewej."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Przenieś okno na obszar roboczy po prawej"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Skrót do przenoszenia aktywnego okna na obszar roboczy po prawej."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Wyrównaj okno do środka"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Skrót do wyrównywania aktywnego okna do środka bez zmiany jego rozmiaru."

#: src/prefs.js:583
msgid "Increase Gap Size"
msgstr "Zwiększ rozmiar odstępu"

#: src/prefs.js:584
msgid "Shortcut to increase the gap size."
msgstr "Skrót do zwiększania rozmiaru odstępu."

#: src/prefs.js:594
msgid "Decrease Gap Size"
msgstr "Zmniejsz rozmiar odstępu"

#: src/prefs.js:595
msgid "Shortcut to decrease the gap size."
msgstr "Skrót do zmniejszania rozmiaru odstępu."

#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Kafelkuj okno na środku"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Skrót do kafelkowania aktywnego okna na środku."

#: src/prefs.js:616
msgid "Tile Window to Left"
msgstr "Kafelkuj okno po lewej"

#: src/prefs.js:617
msgid "Shortcut to tile the active window to left."
msgstr "Skrót do kafelkowania aktywnego okna po lewej."

#: src/prefs.js:627
msgid "Tile Window to Right"
msgstr "Kafelkuj okno po prawej"

#: src/prefs.js:628
msgid "Shortcut to tile the active window to right."
msgstr "Skrót do kafelkowania aktywnego okna po prawej."

#: src/prefs.js:638
msgid "Tile Window to Top"
msgstr "Kafelkuj okno na górze"

#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Skrót do kafelkowania aktywnego okna na górze."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Kafelkuj okno na dole"

#: src/prefs.js:650
msgid "Shortcut to tile the active window to bottom."
msgstr "Skrót do kafelkowania aktywnego okna na dole."

#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Kafelkuj okno w lewym górnym rogu"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Skrót do kafelkowania aktywnego okna w lewym górnym rogu."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Kafelkuj okno w prawym górnym rogu"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Skrót do kafelkowania aktywnego okna w prawym górnym rogu."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Kafelkuj okno w lewym dolnym rogu"

#: src/prefs.js:684
msgid "Shortcut to tile the active window to bottom left."
msgstr "Skrót do kafelkowania aktywnego okna w lewym dolnym rogu."

#: src/prefs.js:694
msgid "Tile Window to Bottom Right"
msgstr "Kafelkuj okno w prawym dolnym rogu"

#: src/prefs.js:695
msgid "Shortcut to tile the active window to bottom right."
msgstr "Skrót do kafelkowania aktywnego okna w prawym dolnym rogu."

#: src/prefs.js:743
msgid "Disabled"
msgstr "Wyłączone"

#: src/prefs.js:756
msgid "Default workspace shortcuts (Super + Page Up/Down) conflict with this extension on keyboards where Numpad 9 and 3 share those keys. Enabling this fix overrides system defaults to ensure proper numpad tiling."
msgstr "Domyślne skróty obszarów roboczych (Super + Page Up/Down) kolidują z tym rozszerzeniem na klawiaturach, gdzie Numpad 9 i 3 współdzielą te klawisze. Włączenie tej poprawki nadpisuje domyślne ustawienia systemowe, aby zapewnić prawidłowe kafelkowanie numeryczne."

#: src/prefs.js:760
msgid "Enable Override"
msgstr "Włącz nadpisywanie"

#: src/prefs.js:765
msgid "Close"
msgstr "Zamknij"

#: src/prefs.js:771
msgid "About"
msgstr "O rozszerzeniu"

#: src/prefs.js:803
msgid "A powerful tiling manager for GNOME Shell. Precision tile windows into 9 positions using the number pad, enjoy dynamic grid sizes that cycle on repeated keystrokes, and experience seamless linked resizing for adjacent windows. Includes customizable gaps, center alignment, and integrated workspace navigation."
msgstr "Potężny menedżer kafelkowania dla GNOME Shell. Precyzyjne kafelkowanie okien w 9 pozycjach za pomocą klawiatury numerycznej, dynamiczne rozmiary siatki zmieniające się przy powtarzających się naciśnięciach klawiszy oraz płynne powiązane zmienianie rozmiaru sąsiednich okien. Zawiera konfigurowalne odstępy, wyrównanie do środka i zintegrowaną nawigację po obszarach roboczych."

