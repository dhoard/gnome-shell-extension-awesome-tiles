#: src/prefs.js:55 src/prefs.js:87
msgid "Behavior"
msgstr "Поведение"

#: src/prefs.js:64 src/prefs.js:195
msgid "Gaps"
msgstr "Отступы"

#: src/prefs.js:73 src/prefs.js:477
msgid "Shortcuts"
msgstr "Горячие клавиши"

#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Включить анимацию окон"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Анимировать окна при изменении их размера или положения (может работать некорректно в Wayland)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Таймаут итерации горячей клавиши в миллисекундах"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "Временное окно для того, чтобы считать новое нажатие клавиши итерацией."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Шаги тайлинга по центру"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Шаги при каждом нажатии клавиши (значения от 0 до 1)."

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Шаги бокового тайлинга"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Включить связанное изменение размера окон"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "При удерживании Alt и изменении размера окна соседние тайловые окна будут изменять размер вместе для сохранения отступа."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Использовать акцентный цвет темы"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Цвет свечения связанного изменения размера"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Пользовательский цвет для эффекта свечения при связанном изменении размера (в шестнадцатеричном формате, например, #3584e4). Оставьте пустым, чтобы использовать акцентный цвет темы."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Использовать пиксели для размера отступа"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Использовать пиксели вместо процентов для размера отступа."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Отступы между окнами"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Добавлять отступы между окнами."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Включить индивидуальные размеры отступов"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Настройте отдельные размеры отступов для каждой стороны (сверху, слева, снизу, справа) и между окнами."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Размер отступа сверху"

#: src/prefs.js:236
msgid "Gap size at the top (percent)."
msgstr "Размер отступа сверху (в процентах)."

#: src/prefs.js:252
msgid "Left Gap Size"
msgstr "Размер отступа слева"

#: src/prefs.js:253
msgid "Gap size at the left (percent)."
msgstr "Размер отступа слева (в процентах)."

#: src/prefs.js:269
msgid "Right Gap Size"
msgstr "Размер отступа справа"

#: src/prefs.js:270
msgid "Gap size at the right (percent)."
msgstr "Размер отступа справа (в процентах)."

#: src/prefs.js:286 src/prefs.js:425
msgid "Bottom Gap Size"
msgstr "Размер отступа снизу"

#: src/prefs.js:287
msgid "Gap size at the bottom (percent)."
msgstr "Размер отступа снизу (в процентах)."

#: src/prefs.js:303
msgid "Inner Gap Size"
msgstr "Размер внутреннего отступа"

#: src/prefs.js:304
msgid "Gap size between windows (percent)."
msgstr "Размер отступа между окнами (в процентах)."

#: src/prefs.js:339
msgid "pixels"
msgstr "пикселей"

#: src/prefs.js:339
msgid "percent"
msgstr "процентов"

#: src/prefs.js:340
