#: src/prefs.js:342
msgid "Gap size at the right"
msgstr "Размер отступа справа"

#: src/prefs.js:343
msgid "Gap size at the bottom"
msgstr "Размер отступа снизу"

#: src/prefs.js:344
msgid "Gap size between windows"
msgstr "Размер отступа между окнами"

#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Отступ между окном и рабочей областью"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Процент, оставляемый в качестве отступа при тайлинге окна."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Пиксели, оставляемые в качестве отступа при тайлинге окна."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Шаг изменения размера отступа"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Изменение размера отступа при использовании горячих клавиш."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Включить дополнительный отступ снизу"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Добавить дополнительный отступ внизу экрана для предотвращения перекрытия дока."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Размер дополнительного отступа внизу экрана в процентах."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Размер дополнительного отступа внизу экрана в пикселях."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Отступ снизу только на основном экране"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Применять дополнительный отступ снизу только на основном экране."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Назначить горячие клавиши для функций"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Исправить Numpad 9 и Numpad 3"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Исправление тайлинга Numpad"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Устраните конфликты горячих клавиш переключения рабочих областей на некоторых клавиатурах, переопределив системные настройки по умолчанию в соответствии с настройками расширения."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Модификатор связанного изменения размера"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "Клавиша-модификатор, удерживаемая при изменении размера для активации связанного изменения размера."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Переключиться на рабочую область слева"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Горячая клавиша для переключения на рабочую область слева."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Переключиться на рабочую область справа"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Горячая клавиша для переключения на рабочую область справа."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Переместить окно на рабочую область слева"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Горячая клавиша для перемещения текущего окна на рабочую область слева."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Переместить окно на рабочую область справа"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Горячая клавиша для перемещения текущего окна на рабочую область справа."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Выровнять окно по центру"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Горячая клавиша для выравнивания активного окна по центру без изменения его размера."

#: src/prefs.js:583
msgid "Increase Gap Size"
msgstr "Увеличить размер отступа"

#: src/prefs.js:584
msgid "Shortcut to increase the gap size."
msgstr "Горячая клавиша для увеличения размера отступа."

#: src/prefs.js:594
msgid "Decrease Gap Size"
msgstr "Уменьшить размер отступа"

#: src/prefs.js:595
msgid "Shortcut to decrease the gap size."
msgstr "Горячая клавиша для уменьшения размера отступа."

#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Разместить окно по центру"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Горячая клавиша для тайлинга активного окна по центру."

#: src/prefs.js:616
msgid "Tile Window to Left"
msgstr "Разместить окно слева"

#: src/prefs.js:617
msgid "Shortcut to tile the active window to left."
msgstr "Горячая клавиша для тайлинга активного окна слева."

#: src/prefs.js:627
msgid "Tile Window to Right"
msgstr "Разместить окно справа"

#: src/prefs.js:628
msgid "Shortcut to tile the active window to right."
msgstr "Горячая клавиша для тайлинга активного окна справа."

#: src/prefs.js:638
msgid "Tile Window to Top"
msgstr "Разместить окно вверху"

#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Горячая клавиша для тайлинга активного окна вверху."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Разместить окно внизу"

#: src/prefs.js:650
msgid "Shortcut to tile the active window to bottom."
msgstr "Горячая клавиша для тайлинга активного окна внизу."

#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Разместить окно в левом верхнем углу"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Горячая клавиша для тайлинга активного окна в левый верхний угол."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Разместить окно в правом верхнем углу"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Горячая клавиша для тайлинга активного окна в правый верхний угол."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Разместить окно в левом нижнем углу"

#: src/prefs.js:684
msgid "Shortcut to tile the active window to bottom left."
msgstr "Горячая клавиша для тайлинга активного окна в левый нижний угол."

#: src/prefs.js:694
msgid "Tile Window to Bottom Right"
msgstr "Разместить окно в правом нижнем углу"

#: src/prefs.js:695
msgid "Shortcut to tile the active window to bottom right."
msgstr "Горячая клавиша для тайлинга активного окна в правый нижний угол."

#: src/prefs.js:743
msgid "Disabled"
msgstr "Отключено"

#: src/prefs.js:756
msgid "Default workspace shortcuts (Super + Page Up/Down) conflict with this extension on keyboards where Numpad 9 and 3 share those keys. Enabling this fix overrides system defaults to ensure proper numpad tiling."
msgstr "Стандартные горячие клавиши рабочих областей (Super + Page Up/Down) конфликтуют с этим расширением на клавиатурах, где клавиши Numpad 9 and 3 совмещены с этими функциями. Включение этого исправления переопределяет системные настройки для обеспечения корректного тайлинга с помощью цифровой клавиатуры."

#: src/prefs.js:760
msgid "Enable Override"
msgstr "Включить переопределение"

#: src/prefs.js:765
msgid "Close"
msgstr "Закрыть"

#: src/prefs.js:771
msgid "About"
msgstr "О расширении"

#: src/prefs.js:803
msgid "A powerful tiling manager for GNOME Shell. Precision tile windows into 9 positions using the number pad, enjoy dynamic grid sizes that cycle on repeated keystrokes, and experience seamless linked resizing for adjacent windows. Includes customizable gaps, center alignment, and integrated workspace navigation."
msgstr "Мощный менеджер тайлинга для GNOME Shell. Точное размещение окон в 9 позициях с помощью цифровой клавиатуры, динамические размеры сетки, сменяющиеся при повторных нажатиях клавиш, и плавное связанное изменение размера соседних окон. Включает настраиваемые отступы, выравнивание по центру и интегрированную навигацию по рабочим областям."

