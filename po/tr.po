msgstr[1] "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:55 src/prefs.js:87
msgid "Behavior"
msgstr "Davranış"

#: src/prefs.js:64 src/prefs.js:195
msgid "Gaps"
msgstr "Boşluklar"

#: src/prefs.js:73 src/prefs.js:477
msgid "Shortcuts"
msgstr "Kısayollar"

#: src/prefs.js:91
msgid "Enable Window Animations"
msgstr "Pencere Animasyonlarını Etkinleştir"

#: src/prefs.js:92
msgid "Animate windows when resized or repositioned (this may be buggy on Wayland)."
msgstr "Pencerelere yeniden boyutlandırma veya taşıma sırasında animasyon uygula (Wayland oturumlarında düzgün çalışmayabilir)."

#: src/prefs.js:103
msgid "Shortcut Iteration Timeout in Milliseconds"
msgstr "Kısayol Yineleme Zaman Aşımı Millisaniyesi"

#: src/prefs.js:104
msgid "The time window to consider a new key press an iteration."
msgstr "Yeni tuş basımını yineleme saymak için gereken zaman aralığı."

#: src/prefs.js:123
msgid "Center Tiling Steps"
msgstr "Ortaya Döşeme Aralıkları"

#: src/prefs.js:124 src/prefs.js:140
msgid "Steps on each key press (values between 0-1)."
msgstr "Her basım için uygulanacak aralıklar (0-1 arası değerler)."

#: src/prefs.js:139
msgid "Side Tiling Steps"
msgstr "Kenara Döşeme Aralıkları"

#: src/prefs.js:152
msgid "Enable Linked Window Resize"
msgstr "Bağlantılı Pencere Boyutlandırmayı Etkinleştir"

#: src/prefs.js:153
msgid "When holding Alt and resizing a window, adjacent tiled windows will resize together to maintain the gap."
msgstr "Alt tuşuna basılı tutarak bir pencereyi yeniden boyutlandırırken, bitişik döşenmiş pencereler boşluğu korumak için birlikte yeniden boyutlandırılır."

#: src/prefs.js:165
msgid "Use theme accent color"
msgstr "Tema vurgu rengini kullan"

#: src/prefs.js:169
msgid "Linked Resize Glow Color"
msgstr "Bağlantılı Boyutlandırma Parlama Rengi"

#: src/prefs.js:170
msgid "Custom color for the glow effect during linked resize (hex format like #3584e4). Leave empty to use theme accent color."
msgstr "Bağlantılı yeniden boyutlandırma sırasındaki parlama efekti için özel renk (#3584e4 gibi hex formatında). Tema vurgu rengini kullanmak için boş bırakın."

#: src/prefs.js:199
msgid "Use Pixels for Gap Size"
msgstr "Boşluk Büyüklüğünü Azalt"

#: src/prefs.js:200
msgid "Use pixels instead of percentage for gap size."
msgstr "Boşluk boyutu için yüzde yerine piksel kullan."

#: src/prefs.js:211
msgid "Gaps Between Windows"
msgstr "Pencereler Arasında Boşluk"

#: src/prefs.js:212
msgid "Put gaps between windows."
msgstr "Pencerelerin arasına boşluk koy."

#: src/prefs.js:223
msgid "Enable Individual Gap Sizes"
msgstr "Bireysel Boşluk Boyutlarını Etkinleştir"

#: src/prefs.js:224
msgid "Configure separate gap sizes for each side (top, left, bottom, right) and between windows."
msgstr "Her bir taraf (üst, sol, alt, sağ) ve pencereler arası için ayrı boşluk boyutları yapılandırın."

#: src/prefs.js:235
msgid "Top Gap Size"
msgstr "Boşluk Büyüklüğünü Arttır"

#: src/prefs.js:236
msgid "Gap size at the top (percent)."
msgstr "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:252
msgid "Left Gap Size"
msgstr "Boşluk Büyüklüğünü Arttır"

#: src/prefs.js:253
msgid "Gap size at the left (percent)."
msgstr "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:269
msgid "Right Gap Size"
msgstr "Sağ Boşluk Boyutu"

#: src/prefs.js:270
msgid "Gap size at the right (percent)."
msgstr "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:286 src/prefs.js:425
msgid "Bottom Gap Size"
msgstr "Alt Boşluk Boyutu"

#: src/prefs.js:287
msgid "Gap size at the bottom (percent)."
msgstr "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:303
msgid "Inner Gap Size"
msgstr "Boşluk Büyüklüğünü Arttır"

#: src/prefs.js:304
msgid "Gap size between windows (percent)."
msgstr "Pencerelerin arasına boşluk koy."

#: src/prefs.js:339
msgid "pixels"
msgstr "piksel"

#: src/prefs.js:339
msgid "percent"
msgstr "yüzde"

#: src/prefs.js:340
msgid "Gap size at the top"
msgstr "Üstteki boşluk boyutu"

#: src/prefs.js:341
msgid "Gap size at the left"
msgstr "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:342
msgid "Gap size at the right"
msgstr "Boşluk aralığı artık yüzde %d oranında"

#: src/prefs.js:343
msgid "Gap size at the bottom"
msgstr "Alttaki boşluk boyutu"

#: src/prefs.js:344
msgid "Gap size between windows"
msgstr "Pencereler Arasında Boşluk"

#: src/prefs.js:357
msgid "Gap Between Window and Workspace"
msgstr "Pencere ve Çalışma Alanı Arasındaki Boşluk"

#: src/prefs.js:358 src/prefs.js:378
msgid "Percentage to leave out as gap when a window is tiled."
msgstr "Bir pencere döşendiğinde boşluk olarak bırakılacak yüzde oranı."

#: src/prefs.js:377
msgid "Pixels to leave out as gap when a window is tiled."
msgstr "Bir pencere döşendiğinde boşluk olarak bırakılacak yüzde oranı."

#: src/prefs.js:388
msgid "Gap Size Increments"
msgstr "Boşluk Büyüklüğü Değişimleri"

#: src/prefs.js:389
msgid "The change that the shorcuts make in the gap size."
msgstr "Kısayolların boşluk büyüklüğünde yapacağı değişiklik oranı."

#: src/prefs.js:413
msgid "Enable Additional Bottom Gap"
msgstr "Ek Alt Boşluğu Etkinleştir"

#: src/prefs.js:414
msgid "Add an additional gap at the bottom of the screen to prevent dock overlap."
msgstr "Rıhtım (dock) çakışmasını önlemek için ekranın altına ek bir boşluk ekleyin."

#: src/prefs.js:426 src/prefs.js:445
msgid "Additional gap size at the bottom of the screen in percentage."
msgstr "Ekranın altındaki ek boşluk boyutu yüzde olarak."

#: src/prefs.js:444
msgid "Additional gap size at the bottom of the screen in pixels."
msgstr "Ekranın altındaki ek boşluk boyutu piksel olarak."

#: src/prefs.js:453
msgid "Bottom Gap Main Screen Only"
msgstr "Sadece Ana Ekranda Alt Boşluk"

#: src/prefs.js:454
msgid "Apply the additional bottom gap only on the main screen."
msgstr "Ek alt boşluğu yalnızca ana ekranda uygula."

#: src/prefs.js:478
msgid "Assign shortcuts to the functionalities"
msgstr "Özelliklere kısayol atayın"

#: src/prefs.js:483 src/prefs.js:755
msgid "Fix Numpad 9 and Numpad 3"
msgstr "Numpad 9 ve Numpad 3'ü Düzelt"

#: src/prefs.js:487
msgid "Numpad Tiling Fix"
msgstr "Numpad Döşeme Düzeltmesi"

#: src/prefs.js:488
msgid "Resolve workspace switching shortcut conflicts on certain keyboards by overriding system defaults to match extension settings."
msgstr "Sistem varsayılanlarını uzantı ayarlarıyla eşleşecek şekilde geçersiz kılarak belirli klavyelerdeki çalışma alanı değiştirme kısayolu çakışmalarını çözün."

#: src/prefs.js:499
msgid "Linked Resize Modifier"
msgstr "Bağlantılı Boyutlandırma Değiştirici Tuşu"

#: src/prefs.js:500
msgid "The modifier key held while resizing to trigger linked resizing."
msgstr "Bağlantılı boyutlandırmayı tetiklemek için boyutlandırma sırasında basılı tutulan değiştirici tuş."

#: src/prefs.js:512
msgid "Switch to Workspace Left"
msgstr "Sol Çalışma Alanına Geç"

#: src/prefs.js:513
msgid "Shortcut to switch to the workspace on the left."
msgstr "Pencereyi sola döşemek için kullanılacak kısayol."

#: src/prefs.js:523
msgid "Switch to Workspace Right"
msgstr "Sağ Çalışma Alanına Geç"

#: src/prefs.js:524
msgid "Shortcut to switch to the workspace on the right."
msgstr "Pencereyi sağa döşemek için kullanılacak kısayol."

#: src/prefs.js:534
msgid "Move Window to Workspace Left"
msgstr "Pencereyi Sol Yukarı Döşe"

#: src/prefs.js:535
msgid "Shortcut to move the focused window to the workspace on the left."
msgstr "Pencereyi sol yukarı döşemek için kullanılacak kısayol."

#: src/prefs.js:545
msgid "Move Window to Workspace Right"
msgstr "Pencereyi Sağ Yukarı Döşe"

#: src/prefs.js:546
msgid "Shortcut to move the focused window to the workspace on the right."
msgstr "Pencereyi sağ yukarı döşemek için kullanılacak kısayol."

#: src/prefs.js:572
msgid "Align Window to Center"
msgstr "Pencereyi Ortaya Hizala"

#: src/prefs.js:573
msgid "Shortcut to align the active window to center without resizing it."
msgstr "Aktif pencereyi yeniden boyutlandırmadan ortalayacak kısayol."

#: src/prefs.js:583
msgid "Increase Gap Size"
msgstr "Boşluk Büyüklüğünü Arttır"

#: src/prefs.js:584
msgid "Shortcut to increase the gap size."
msgstr "Boşluk büyüklüğünü arttırmak için kullanılacak kısayol."

#: src/prefs.js:594
msgid "Decrease Gap Size"
msgstr "Boşluk Büyüklüğünü Azalt"

#: src/prefs.js:595
msgid "Shortcut to decrease the gap size."
msgstr "Boşluk büyüklüğünü azaltmak için kullanılacak kısayol."

#: src/prefs.js:605
msgid "Tile Window to Center"
msgstr "Pencereyi Ortaya Döşe"

#: src/prefs.js:606
msgid "Shortcut to tile active window to center."
msgstr "Pencereyi ortaya döşemek için kullanılacak kısayol."

#: src/prefs.js:616
msgid "Tile Window to Left"
msgstr "Pencereyi Sola Döşe"

#: src/prefs.js:617
msgid "Shortcut to tile the active window to left."
msgstr "Pencereyi sola döşemek için kullanılacak kısayol."

#: src/prefs.js:627
msgid "Tile Window to Right"
msgstr "Pencereyi Sağa Döşe"

#: src/prefs.js:628
msgid "Shortcut to tile the active window to right."
msgstr "Pencereyi sağa döşemek için kullanılacak kısayol."

#: src/prefs.js:638
msgid "Tile Window to Top"
msgstr "Pencereyi Yukarı Döşe"

#: src/prefs.js:639
msgid "Shortcut to tile the active window to top."
msgstr "Pencereyi yukarı döşemek için kullanılacak kısayol."

#: src/prefs.js:649
msgid "Tile Window to Bottom"
msgstr "Pencereyi Aşağı Döşe"

#: src/prefs.js:650
msgid "Shortcut to tile the active window to bottom."
msgstr "Pencereyi aşağı döşemek için kullanılacak kısayol."

#: src/prefs.js:660
msgid "Tile Window to Top Left"
msgstr "Pencereyi Sol Yukarı Döşe"

#: src/prefs.js:661
msgid "Shortcut to tile the active window to top left."
msgstr "Pencereyi sol yukarı döşemek için kullanılacak kısayol."

#: src/prefs.js:671
msgid "Tile Window to Top Right"
msgstr "Pencereyi Sağ Yukarı Döşe"

#: src/prefs.js:672
msgid "Shortcut to tile the active window to top right."
msgstr "Pencereyi sağ yukarı döşemek için kullanılacak kısayol."

#: src/prefs.js:683
msgid "Tile Window to Bottom Left"
msgstr "Pencereyi Sol Aşağı Döşe"

#: src/prefs.js:684
msgid "Shortcut to tile the active window to bottom left."
msgstr "Pencereyi sol asağı döşemek için kullanılacak kısayol."

#: src/prefs.js:694
msgid "Tile Window to Bottom Right"
msgstr "Pencereyi Sağ Aşağı Döşe"

#: src/prefs.js:695
msgid "Shortcut to tile the active window to bottom right."
msgstr "Pencereyi sağ aşağı döşemek için kullanılacak kısayol."

#: src/prefs.js:743
msgid "Disabled"
msgstr "Devre dışı"

#: src/prefs.js:756
msgid "Default workspace shortcuts (Super + Page Up/Down) conflict with this extension on keyboards where Numpad 9 and 3 share those keys. Enabling this fix overrides system defaults to ensure proper numpad tiling."
msgstr "Varsayılan çalışma alanı kısayolları (Super + Page Up/Down), Numpad 9 ve 3'ün bu tuşları paylaştığı klavyelerde bu uzantıyla çakışıyor. Bu düzeltmeyi etkinleştirmek, düzgün numpad döşemesi sağlamak için sistem varsayılanlarını geçersiz kılar."

#: src/prefs.js:760
msgid "Enable Override"
msgstr "Üzerine Yazmayı Etkinleştir"

#: src/prefs.js:765
msgid "Close"
msgstr "Kapat"

#: src/prefs.js:771
msgid "About"
msgstr "Hakkında"

#: src/prefs.js:803
msgid "A powerful tiling manager for GNOME Shell. Precision tile windows into 9 positions using the number pad, enjoy dynamic grid sizes that cycle on repeated keystrokes, and experience seamless linked resizing for adjacent windows. Includes customizable gaps, center alignment, and integrated workspace navigation."
msgstr "GNOME Shell için güçlü bir döşeme yöneticisi. Pencereleri sayısal tuş takımını kullanarak 9 konuma hassas bir şekilde döşeyin, yinelenen tuş basışlarıyla değişen dinamik ızgara boyutlarının keyfini çıkarın ve bitişik pencereler için sorunsuz bağlantılı yeniden boyutlandırmayı deneyimleyin. Özelleştirilebilir boşluklar, merkez hizalama ve entegre çalışma alanı navigasyonu içerir."

